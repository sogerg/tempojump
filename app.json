{
  "expo": {
    "name": "TempoJump",
    "slug": "mon-appli-cavalier",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.sogerg.monappcavalier",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "buildNumber": "4"
    },
    "android": {
      "package": "com.sogerg.monappcavalier",
      "versionCode": 2,
      "adaptiveIcon": {
        "backgroundColor": "#0A2844",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.INTERNET"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-localization",
      "expo-audio",
      "expo-sharing",
      "expo-video",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Autorise l'accès à la caméra pour photographier les plans de parcours et filmer tes reprises.",
          "microphonePermission": "Autorise l'accès au micro pour filmer tes reprises avec le son.",
          "photosPermission": "Autorise l'accès à tes photos pour choisir un plan de parcours ou une vidéo."
        }
      ],
      "expo-file-system",
      "expo-font",
      [
        "expo-navigation-bar",
        {
          "hidden": true
        }
      ],
      [
        "expo-status-bar",
        {
          "hidden": true
        }
      ],
      "./plugins/withReleaseSigning.js"
    ],
    "extra": {
      "expo-navigation-bar": {
        "hidden": true
      },
      "expo-status-bar": {
        "hidden": true
      },
      "eas": {
        "projectId": "2bcded99-f727-4fc0-9a2c-fc8c191b9430"
      }
    },
    "owner": "sogerg"
  }
}
